<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>TaskFlow Premium</title>

<style>
/* ==================================================
   TASKFLOW PREMIUM - SINGLE FILE APP
================================================== */

:root{
  --bg1:#f4f7ff;
  --bg2:#eaf0ff;
  --card:rgba(255,255,255,.55);
  --text:#111;
  --muted:#555;
  --line:rgba(255,255,255,.35);
  --shadow:0 10px 30px rgba(0,0,0,.08);
  --accent:#5b7cff;
  --accent2:#7a5cff;
  --success:#11c26d;
  --danger:#ff4d6d;
}

body.dark{
  --bg1:#090909;
  --bg2:#151515;
  --card:rgba(255,255,255,.06);
  --text:#fff;
  --muted:#bbb;
  --line:rgba(255,255,255,.08);
  --shadow:0 10px 30px rgba(0,0,0,.55);
  --accent:#66a8ff;
  --accent2:#8d6bff;
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  font-family:Inter,Segoe UI,Arial,sans-serif;
  background:linear-gradient(135deg,var(--bg1),var(--bg2));
  color:var(--text);
  min-height:100vh;
  transition:.4s;
  overflow-x:hidden;
}

/* floating blobs */
body::before,
body::after{
  content:"";
  position:fixed;
  width:320px;
  height:320px;
  border-radius:50%;
  filter:blur(70px);
  z-index:-1;
  animation:floatBlob 9s ease-in-out infinite;
}

body::before{
  background:#6e8bff55;
  top:-100px;
  left:-80px;
}

body::after{
  background:#9b6dff55;
  right:-80px;
  bottom:-120px;
  animation-delay:2s;
}

@keyframes floatBlob{
  50%{transform:translateY(40px) scale(1.15);}
}

.container{
  width:min(1200px,95%);
  margin:auto;
  padding:24px 0 40px;
}

.topbar{
  display:flex;
  flex-wrap:wrap;
  gap:15px;
  justify-content:space-between;
  align-items:center;
  margin-bottom:20px;
}

.logo{
  font-size:28px;
  font-weight:800;
  letter-spacing:.4px;
}

.logo span{
  background:linear-gradient(90deg,var(--accent),var(--accent2));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.clock{
  font-weight:600;
  color:var(--muted);
}

.row{
  display:grid;
  grid-template-columns:1.3fr .7fr;
  gap:20px;
}

@media(max-width:900px){
  .row{
    grid-template-columns:1fr;
  }
}

.card{
  background:var(--card);
  border:1px solid var(--line);
  box-shadow:var(--shadow);
  backdrop-filter:blur(18px);
  border-radius:24px;
  padding:22px;
  animation:fadeUp .5s ease;
}

@keyframes fadeUp{
  from{opacity:0;transform:translateY(20px)}
  to{opacity:1;transform:none}
}

h2{
  font-size:20px;
  margin-bottom:15px;
}

.controls{
  display:grid;
  grid-template-columns:2fr 1fr 1fr 1fr auto;
  gap:10px;
}

@media(max-width:900px){
  .controls{
    grid-template-columns:1fr;
  }
}

input,select{
  width:100%;
  padding:13px 14px;
  border:none;
  outline:none;
  border-radius:16px;
  background:rgba(255,255,255,.55);
  color:#111;
}

body.dark input,
body.dark select{
  background:rgba(255,255,255,.08);
  color:#fff;
}

.btn{
  border:none;
  padding:13px 18px;
  border-radius:16px;
  cursor:pointer;
  color:#fff;
  font-weight:700;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  transition:.25s;
  position:relative;
  overflow:hidden;
}

.btn:hover{
  transform:translateY(-2px);
  box-shadow:0 8px 20px rgba(91,124,255,.35);
}

.btn:active{
  transform:scale(.96);
}

.small-btn{
  padding:9px 12px;
  font-size:13px;
}

.toolbar{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin:16px 0;
}

.pill{
  padding:10px 14px;
  border:none;
  border-radius:999px;
  cursor:pointer;
  background:var(--card);
  color:var(--text);
  border:1px solid var(--line);
}

.pill.active{
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  color:#fff;
}

.search{
  margin-bottom:16px;
}

.task-list{
  min-height:260px;
}

.task{
  display:grid;
  grid-template-columns:auto 1fr auto;
  gap:14px;
  align-items:center;
  padding:14px;
  border-radius:18px;
  background:rgba(255,255,255,.28);
  margin-bottom:12px;
  border:1px solid var(--line);
  animation:slideIn .35s ease;
  cursor:grab;
}

body.dark .task{
  background:rgba(255,255,255,.04);
}

@keyframes slideIn{
  from{opacity:0;transform:translateX(-20px)}
  to{opacity:1;transform:none}
}

.task.done{
  opacity:.65;
}

.task.done .title{
  text-decoration:line-through;
}

.check{
  width:22px;
  height:22px;
  accent-color:var(--success);
}

.title{
  font-weight:700;
}

.meta{
  font-size:13px;
  color:var(--muted);
  margin-top:4px;
}

.actions{
  display:flex;
  gap:8px;
}

.icon{
  width:38px;
  height:38px;
  border:none;
  border-radius:12px;
  cursor:pointer;
  color:var(--text);
  background:var(--card);
}

.icon:hover{
  transform:scale(1.05);
}

.progress{
  height:12px;
  background:rgba(255,255,255,.2);
  border-radius:999px;
  overflow:hidden;
  margin-top:10px;
}

.bar{
  height:100%;
  width:0%;
  background:linear-gradient(90deg,var(--success),#59ffc5);
  transition:.5s;
}

.quote{
  margin-top:18px;
  font-style:italic;
  color:var(--muted);
  min-height:55px;
}

.empty{
  text-align:center;
  padding:35px;
  color:var(--muted);
}

.theme-toggle{
  margin-left:black;
}

.popup{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.45);
  display:none;
  align-items:center;
  justify-content:center;
  z-index:999;
}

.popup-box{
  width:min(430px,92%);
  padding:24px;
  border-radius:24px;
  background:var(--card);
  backdrop-filter:blur(18px);
  border:1px solid var(--line);
  box-shadow:var(--shadow);
  animation:fadeUp .3s ease;
}

.popup h3{
  margin-bottom:10px;
}

.popup-actions{
  display:flex;
  gap:10px;
  margin-top:18px;
  flex-wrap:wrap;
}
</style>
</head>
<body>

<div class="container">

  <div class="topbar">
    <div class="logo">TaskFlow <span>Pro</span></div>
    <div class="clock" id="clock">--:--</div>
  </div>

  <div class="row">

    <!-- LEFT -->
    <div class="card">
      <h2>Create Task</h2>

      <div class="controls">
        <input id="taskInput" placeholder="Enter your task..." />
        <select id="category">
          <option>Work</option>
          <option>Study</option>
          <option>Personal</option>
          <option>Important</option>
        </select>
        <input type="date" id="date">
        <input type="time" id="time">
        <button class="btn" onclick="addTask()">Add</button>
      </div>

      <div class="toolbar">
        <button class="pill active" data-filter="all">All</button>
        <button class="pill" data-filter="active">Active</button>
        <button class="pill" data-filter="completed">Completed</button>
        <button class="pill" data-filter="overdue">Overdue</button>

        <button class="pill theme-toggle" onclick="toggleTheme()">🌙 Theme</button>
      </div>

      <div class="search">
        <input id="search" placeholder="Search tasks...">
      </div>

      <div class="task-list" id="taskList"></div>
    </div>

    <!-- RIGHT -->
    <div class="card">
      <h2>Progress</h2>
      <div id="stats">0 of 0 completed</div>
      <div class="progress">
        <div class="bar" id="bar"></div>
      </div>

      <div class="quote" id="quote"></div>
    </div>

  </div>
</div>

<!-- POPUP -->
<div class="popup" id="popup">
  <div class="popup-box">
    <h3>⏰ Task Reminder</h3>
    <p id="popupText"></p>

    <div class="popup-actions">
      <button class="btn small-btn" onclick="completeNow()">Complete Now</button>
      <button class="btn small-btn" onclick="snoozeTask()">Snooze 5 Min</button>
      <button class="pill" onclick="closePopup()">Close</button>
    </div>
  </div>
</div>

<script>
/* ==============================================
   TASKFLOW PREMIUM
============================================== */

let tasks = JSON.parse(localStorage.getItem("taskflow_tasks")) || [];
let filter = "all";
let alarmTaskId = null;

const quotes = [
"Small progress is still progress.",
"Focus on one task at a time.",
"Discipline beats motivation.",
"Your future is built today.",
"Done is better than perfect."
];

function save(){
  localStorage.setItem("taskflow_tasks", JSON.stringify(tasks));
}

function uid(){
  return Date.now() + Math.random();
}

function addTask(){
  const text = taskInput.value.trim();
  if(!text) return;

  tasks.unshift({
    id:uid(),
    text,
    category:category.value,
    date:date.value,
    time:time.value,
    done:false
  });

  taskInput.value="";
  render();
}

taskInput.addEventListener("keydown",e=>{
  if(e.key==="Enter") addTask();
});

function render(){
  save();

  let list = [...tasks];

  const q = search.value.toLowerCase();
  if(q){
    list = list.filter(t=>t.text.toLowerCase().includes(q));
  }

  if(filter==="active") list=list.filter(t=>!t.done);
  if(filter==="completed") list=list.filter(t=>t.done);
  if(filter==="overdue") list=list.filter(t=>isOverdue(t));

  taskList.innerHTML="";

  if(!list.length){
    taskList.innerHTML=`
      <div class="empty">
        📝 No tasks found<br><br>
        Stay productive & add something meaningful.
      </div>`;
  }

  list.forEach(task=>{
    const div=document.createElement("div");
    div.className="task "+(task.done?"done":"");
    div.draggable=true;

    div.innerHTML=`
      <input class="check" type="checkbox" ${task.done?"checked":""}>
      <div>
        <div class="title" contenteditable="true">${task.text}</div>
        <div class="meta">
          ${task.category} • ${task.date||"No Date"} ${task.time||""}
          ${isOverdue(task)&&!task.done ? " • ⛔ Overdue" : ""}
        </div>
      </div>
      <div class="actions">
        <button class="icon">🗑</button>
      </div>
    `;

    // done
    div.querySelector(".check").onchange=()=>{
      task.done=!task.done;
      render();
    };

    // delete
    div.querySelector(".icon").onclick=()=>{
      div.style.opacity="0";
      div.style.transform="translateX(40px)";
      setTimeout(()=>{
        tasks=tasks.filter(x=>x.id!==task.id);
        render();
      },250);
    };

    // edit
    div.querySelector(".title").onblur=(e)=>{
      task.text=e.target.innerText.trim() || task.text;
      render();
    };

    // drag
    div.addEventListener("dragstart",()=>div.classList.add("dragging"));
    div.addEventListener("dragend",()=>{
      div.classList.remove("dragging");
      reorder();
    });

    taskList.appendChild(div);
  });

  updateStats();
}

function reorder(){
  const nodes=[...document.querySelectorAll(".task")];
  const ids = nodes.map((node)=>{
    const txt=node.querySelector(".title").innerText;
    return tasks.find(t=>t.text===txt)?.id;
  }).filter(Boolean);

  tasks.sort((a,b)=>ids.indexOf(a.id)-ids.indexOf(b.id));
  save();
}

taskList.addEventListener("dragover",e=>{
  e.preventDefault();
  const dragging=document.querySelector(".dragging");
  const after=[...taskList.querySelectorAll(".task:not(.dragging)")];

  const next=after.find(box=>{
    return e.clientY <= box.offsetTop + box.offsetHeight/2;
  });

  if(next) taskList.insertBefore(dragging,next);
  else taskList.appendChild(dragging);
});

function updateStats(){
  const total=tasks.length;
  const done=tasks.filter(t=>t.done).length;
  const percent= total? Math.round(done/total*100):0;

  stats.innerText=`${done} of ${total} completed`;
  bar.style.width=percent+"%";
}

function isOverdue(task){
  if(!task.date || !task.time || task.done) return false;
  const due = new Date(task.date+"T"+task.time);
  return new Date()>due;
}

/* FILTER */
document.querySelectorAll(".pill[data-filter]").forEach(btn=>{
  btn.onclick=()=>{
    document.querySelectorAll(".pill[data-filter]").forEach(x=>x.classList.remove("active"));
    btn.classList.add("active");
    filter=btn.dataset.filter;
    render();
  }
});

search.oninput=render;

/* CLOCK */
setInterval(()=>{
  clock.innerText=new Date().toLocaleString();
},1000);

/* QUOTES */
let qi=0;
function rotateQuote(){
  quote.innerText=quotes[qi++ % quotes.length];
}
rotateQuote();
setInterval(rotateQuote,5000);

/* THEME */
function toggleTheme(){
  document.body.classList.toggle("dark");
  localStorage.setItem("taskflow_theme",
    document.body.classList.contains("dark")?"dark":"light"
  );
}

if(localStorage.getItem("taskflow_theme")==="dark"){
  document.body.classList.add("dark");
}

/* ALARM SOUND */
function beep(){
  const ctx = new (window.AudioContext||window.webkitAudioContext)();
  const osc = ctx.createOscillator();
  const gain = ctx.createGain();

  osc.type="sine";
  osc.frequency.value=700;
  gain.gain.value=.06;

  osc.connect(gain);
  gain.connect(ctx.destination);
  osc.start();
  osc.stop(ctx.currentTime+0.5);
}

/* CHECK DUE TASK */
setInterval(()=>{
  const now=new Date();

  tasks.forEach(t=>{
    if(t.done || !t.date || !t.time || t.alerted) return;

    const due = new Date(t.date+"T"+t.time);

    if(now >= due){
      t.alerted=true;
      alarmTaskId=t.id;
      beep();
      popup.style.display="flex";
      popupText.innerText=`"${t.text}" is due now!`;
      save();
    }
  });
},10000);

/* POPUP ACTIONS */
function closePopup(){
  popup.style.display="none";
}

function completeNow(){
  const task=tasks.find(t=>t.id===alarmTaskId);
  if(task) task.done=true;
  closePopup();
  render();
}

function snoozeTask(){
  const task=tasks.find(t=>t.id===alarmTaskId);
  if(task){
    const d=new Date();
    d.setMinutes(d.getMinutes()+5);
    task.date=d.toISOString().slice(0,10);
    task.time=d.toTimeString().slice(0,5);
    task.alerted=false;
  }
  closePopup();
  render();
}

/* INIT */
render();
</script>
